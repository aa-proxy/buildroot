ctrl_interface=/var/run/hostapd
interface=wlan0

hw_mode={{HW_MODE}}
ieee80211be={{BE_MODE}}
ieee80211ax={{AX_MODE}}
ieee80211ac={{AC_MODE}}
ieee80211n={{N_MODE}}
channel={{CHANNEL}}

ieee80211d=1
ieee80211h=1

wmm_enabled=1

ht_capab=[HT40+][SHORT-GI-20][SHORT-GI-40][RX-STBC1]

vht_oper_chwidth=1
vht_oper_centr_freq_seg0_idx=42

he_oper_chwidth=1
he_oper_centr_freq_seg0_idx=42

auth_algs=1
wpa=2
wpa_key_mgmt=WPA-PSK
rsn_pairwise=CCMP
ssid={{SSID}}

wpa_passphrase={{WPA_PASSPHRASE}}
country_code={{COUNTRY_CODE}}
