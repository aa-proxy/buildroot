#!/bin/sh
#
# Activate the external antenna based on external_antenna in config.toml
#

CONFIG_FILE="/etc/aa-proxy-rs/config.toml"

case "$1" in
    start)
        echo "Selecting antennas..."

        if [ ! -f "$CONFIG_FILE" ]; then
            echo "Config file not found: $CONFIG_FILE"
            exit 1
        fi

        # Check if external_antenna is empty or doesn't exist
        if grep -Eq '^\s*external_antenna\s*=\s*$' "$CONFIG_FILE" || ! grep -Eq '^\s*external_antenna\s*=' "$CONFIG_FILE"; then
            echo "external_antenna is empty or not set."
            exit 2
        fi

        # Enable/Disable the required antennas
        # GPIOCHIP 3 PIN 26 = RF2_EN. Driving this LOW will DISABLE internal antenna.
        # GPIOCHIP 3 PIN 27 = RF1_EN. Driving this LOW will DISABLE external antenna.
        if grep -Eq '^\s*external_antenna\s*=\s*true\s*$' "$CONFIG_FILE"; then
            echo "external antenna is enabled"
            gpioset -b -m signal 3 26=0 27=1
        else
            echo "external antenna is disabled"
            gpioset -b -m signal 3 26=1 27=0
        fi
        ;;
    *)
        echo "Usage: $0 {start}"
        exit 1
        ;;
esac

exit 0
